{
  "name": "PhotoVideoEdit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "npx react-native run-android",
    "clean": "rm -rf node_modules && yarn install && yarn clean-pods && cd yarn clean-gradle",
    "clean-gradle": "cd android && ./gradlew clean cleanBuildCache",
    "clean-pods": "cd ios && pod deintegrate && pod install",
    "ios": "npx react-native run-ios",
    "ios13": "npx react-native run-ios --simulator=\"iPhone 13\"",
    "device": "npx react-native run-ios --device=\"iPhone El\"",
    "lint": "eslint .",
    "start": "npx react-native start --reset-cache",
    "list-android-devices": "npx react-native run-android --list-devices",
    "test": "jest",
    "prettier:fix": "prettier --write \"src/**/*.ts\"",
    "prettier": "prettier -c \"src/**/*.ts\""
  },
  "dependencies": {
    "@react-native-camera-roll/camera-roll": "^7.10.0",
    "lottie-react-native": "^6.7.2",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-compressor": "^1.11.0",
    "react-native-create-thumbnail": "^2.1.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.18.1",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-image-crop-picker": "^0.42.0",
    "react-native-image-picker": "^8.2.0",
    "react-native-image-resizer": "^1.4.5",
    "react-native-permissions": "^5.4.0",
    "react-native-reanimated": "^3.7.2",
    "react-native-video": "^6.13.0",
    "styled-components": "^6.1.8"
  },
  "devDependencies": {
